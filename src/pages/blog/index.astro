---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Sidebar from "../../components/Sidebar.astro";
import BottomControls from "../../components/BottomControls.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-white text-slate-900 dark:bg-slate-950 dark:text-slate-100">
    <Header />
    <main class="mx-auto max-w-[1400px] px-4 py-8">
      <div class="grid gap-8 lg:grid-cols-[280px_minmax(0,1fr)]">
        <Sidebar posts={posts} />

        <section class="space-y-8 rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <div class="space-y-3">
            <p class="text-sm uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">Index</p>
            <h1 class="text-3xl font-semibold text-slate-900 dark:text-white">All posts</h1>
          </div>

          <ul class="space-y-6">
            {
              posts.map((post) => (
                <li>
                  <a href={`/blog/${post.slug}/`} class="block space-y-2 rounded-3xl border border-slate-200 bg-white p-6 transition hover:border-slate-300 hover:bg-slate-50 dark:border-slate-800 dark:bg-slate-950 dark:hover:border-slate-700 dark:hover:bg-slate-900">
                    <div>
                      <h4 class="text-lg font-medium text-slate-900 dark:text-white">{post.data.title}</h4>
                      <p class="max-w-full text-slate-600 dark:text-slate-300">{post.data.description}</p>
                    </div>
                    <div class="text-sm text-slate-500 dark:text-slate-400">{post.data.pubDate.toLocaleDateString()}</div>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </main>
    <Footer />
    <BottomControls />
  </body>
</html>
